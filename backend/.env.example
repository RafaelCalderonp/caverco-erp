DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/caverco_erp
SECRET_KEY=cambia-esto-por-una-clave-segura-de-32-caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
ENVIRONMENT=development
APIGATEWAY_TOKEN=tu_token_de_apigateway_cl

# Clave Fernet (urlsafe-base64, 32 bytes) para cifrar credenciales por empresa.
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Obligatoria si ENVIRONMENT != development.
ENCRYPTION_KEY=

# Orígenes permitidos para CORS, separados por coma (sin espacios extra).
# En producción: la URL del frontend en Cloudflare Pages, ej: https://caverco-erp.pages.dev
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
